# Dot 设备（必填）
DOT_API_KEY=dot_app_your_api_key
DOT_DEVICE_ID=YOUR_DEVICE_ID
DOT_BASE_URL=https://dot.mindreset.tech

# Claude 用量显示（可选，二选一）
# 方式1：Anthropic OAuth Token（推荐，macOS 可自动从 Keychain 发现，无需手动配置）
# ANTHROPIC_OAUTH_TOKEN=your_oauth_access_token
# 方式2：自定义 API 端点（兼容 sub2api 等）
# CLAUDE_USAGE_API_URL=https://your-api-url.com
# CLAUDE_USAGE_API_KEY=your_api_key
# CLAUDE_USAGE_ACCOUNT_ID=1

TZ=Asia/Shanghai
